# Copy this file to .env and fill in real values before running docker compose.
# Never commit .env to version control.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=vacation_tracker
POSTGRES_USER=atlas
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=change_me_use_a_strong_password

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
SESSION_SECRET=change_me_use_a_long_random_string

# ── Admin account ─────────────────────────────────────────────────────────────
# On first startup, Atlas creates an admin user in the database using the
# username below and the bcrypt hash as its password.  After that, manage
# users through the in-app admin panel (👥 button, admin only).
#
# Default username if APP_ADMIN_USERNAME is not set: admin
APP_ADMIN_USERNAME=admin

# Bcrypt hash of the admin's initial password.
# Generate from the project directory:
#   npm run gen-hash -- yourpassword
# Paste the output line exactly as printed — the single quotes are required
# to prevent Docker Compose from expanding $ as variable references.
APP_PASSWORD_HASH='$2b$12$replacethiswithyourrealbcrypthash'

# ── Private deployment (docker-compose.yml) ───────────────────────────────────
# Port the app is reachable on from the host. Change if 3000 is taken.
APP_PORT=3000

# ── Public deployment (docker-compose.traefik.yml) ────────────────────────────
# Public hostname Traefik will route and obtain a TLS certificate for.
DOMAIN=atlas.example.com
# Contact address for Let's Encrypt certificate expiry notifications.
ACME_EMAIL=admin@example.com

# Copy this file to .env and fill in real values before running docker-compose.
# Never commit .env to version control.

# PostgreSQL credentials
POSTGRES_DB=vacation_tracker
POSTGRES_USER=atlas
# Use a strong random password: openssl rand -base64 32
POSTGRES_PASSWORD=change_me_use_a_strong_password

# Session signing secret — must be long and random
# Generate with: openssl rand -base64 48
SESSION_SECRET=change_me_use_a_long_random_string

# Bcrypt hash of the single shared access password.
# Generate hash with:
#   node -e "const b=require('bcryptjs'); console.log(b.hashSync('yourpassword', 12))"
# Then paste the output (starting with $2b$) here.
APP_PASSWORD_HASH=$2b$12$replacethiswithyourrealbcrypthash
